{
  "id": "dp_04",
  "title": "RGB거리",
  "stage": 2,
  "level": 2,
  "topic": "dp",
  "concept": "dp",
  "mode": "stdio",
  "description": "N개의 집을 빨강/초록/파랑 중 하나로 칠한다. 이웃한 집은 같은 색이면 안 된다. 각 집을 각 색으로 칠하는 비용이 주어질 때 전체 최소 비용을 구하라.",
  "constraints": [
    "2 ≤ N ≤ 1,000",
    "비용 ≤ 1,000"
  ],
  "ioDescription": {
    "input": "첫 줄 N. 다음 N줄 R G B 비용.",
    "output": "최소 비용."
  },
  "boilerplate": "#include <bits/stdc++.h>\nusing namespace std;\n\nint main() {\n    ios_base::sync_with_stdio(false); cin.tie(NULL);\n    // 여기에 작성\n\n    return 0;\n}\n",
  "examples": [
    {
      "input": "3\n26 40 83\n49 60 57\n13 89 99\n",
      "output": "96\n"
    },
    {
      "input": "2\n1 100 100\n100 1 100\n",
      "output": "2\n"
    }
  ],
  "hiddenTests": [],
  "hints": [
    "dp[i][c] = i번째 집을 색 c로 칠한 최소 누적 비용.",
    "dp[i][R]=cost[i][R]+min(dp[i-1][G], dp[i-1][B]) 식으로."
  ],
  "solution": "#include <bits/stdc++.h>\nusing namespace std;\nint main(){int n;cin>>n;vector<array<int,3>>c(n);for(auto&a:c)cin>>a[0]>>a[1]>>a[2];vector<array<int,3>>dp(n);dp[0]=c[0];for(int i=1;i<n;i++){dp[i][0]=c[i][0]+min(dp[i-1][1],dp[i-1][2]);dp[i][1]=c[i][1]+min(dp[i-1][0],dp[i-1][2]);dp[i][2]=c[i][2]+min(dp[i-1][0],dp[i-1][1]);}cout<<min({dp[n-1][0],dp[n-1][1],dp[n-1][2]})<<\"\\n\";}\n"
}